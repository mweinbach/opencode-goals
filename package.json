{
  "name": "opencode-goals",
  "version": "1.0.1",
  "description": "Persistent goal tracking plugin for OpenCode - Codex Goal Mode implementation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "goal": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./tui": {
      "import": "./dist/tui.tsx",
      "default": "./dist/tui.tsx"
    }
  },
  "files": [
    "dist",
    ".opencode/commands",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp src/tui.tsx dist/tui.tsx",
    "dev": "tsc --watch",
    "cli": "bun src/cli.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.tui.json",
    "test": "npm run typecheck && npm run build && bun test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opencode",
    "plugin",
    "goals",
    "productivity",
    "codex",
    "goal-mode"
  ],
  "author": "mweinbach",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mweinbach/opencode-goals.git"
  },
  "homepage": "https://github.com/mweinbach/opencode-goals#readme",
  "bugs": {
    "url": "https://github.com/mweinbach/opencode-goals/issues"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.14.48",
    "@opentui/keymap": "^0.2.6",
    "@opentui/solid": "^0.2.6",
    "solid-js": "1.9.12"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
